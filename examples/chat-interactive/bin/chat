#!/usr/bin/env php
<?php

/*
 * Entry point for the interactive chat example.
 *
 * Run from the chat-interactive directory after `composer install`:
 *
 *     php bin/chat /path/to/model.gguf
 *
 * Or if you've made it executable (`chmod +x bin/chat`):
 *
 *     ./bin/chat /path/to/model.gguf
 *
 * The actual command logic lives in src/ChatCommand.php. This file's only
 * job is to wire Symfony's Application together with that command and run
 * it. Keeping it small is intentional — copy this file as-is into your own
 * project; the bits worth reading live next door.
 */

declare(strict_types=1);

// Locate the autoloader. The convoluted dance handles both
// `composer install`-in-this-dir (vendor/ at ../vendor) and the
// less-common case where someone has installed this app globally.
foreach ([
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
] as $autoloadPath) {
    if (is_file($autoloadPath)) {
        require $autoloadPath;
        break;
    }
}
if (!class_exists(\Composer\Autoload\ClassLoader::class)) {
    fwrite(
        STDERR,
        "Autoloader not found. Run `composer install` in this directory first.\n",
    );
    exit(1);
}

if (!extension_loaded('infer')) {
    fwrite(
        STDERR,
        "ext-infer is not loaded. Install it (`make install` from the repo root) or\n"
        . "add `-d extension=…libinfer.so` to your php command line, then re-run.\n",
    );
    exit(1);
}

use ExtInferExample\ChatCommand;
use Symfony\Component\Console\Application;

$command = new ChatCommand();
$application = new Application('ext-infer chat', '0.1.0');
$application->add($command);
// SingleCommandApplication-style: typing `bin/chat <model>` runs the command
// directly instead of requiring `bin/chat chat <model>`.
$application->setDefaultCommand($command->getName(), true);
$application->run();
